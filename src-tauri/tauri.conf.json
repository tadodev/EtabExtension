{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "etabextension",
  "version": "0.1.0",
  "identifier": "tado.tt.etabextension",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EtabExtension",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "windows": {
    "allowDowngrades": true,
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
    }},
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
    
  }
}
